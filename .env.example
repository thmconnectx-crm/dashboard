APP_NAME="Paid Traffic Dashboard"
# Leave empty to generate a strong local secret in data/.app_secret_key.
# In production, define a stable random value and keep it secret.
APP_SECRET_KEY=""
DATABASE_URL="sqlite:///./data/traffic_reports.sqlite3"
BASE_URL="http://127.0.0.1:8000"
ENVIRONMENT="local"
TRUSTED_HOSTS="127.0.0.1,localhost"
AUTO_SYNC_ENABLED="false"
AUTO_SYNC_TIME="03:00"
AUTO_SYNC_PERIOD_DAYS="1"
AUTO_SYNC_PLATFORMS="google,meta"

# Google Ads API
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""
GOOGLE_ADS_API_VERSION="v24"
GOOGLE_ADS_REFRESH_TOKEN=""

# Meta Marketing API / Graph API
META_APP_ID=""
META_APP_SECRET=""
META_GRAPH_API_VERSION="v25.0"
META_ACCESS_TOKEN=""

# Optional comma-separated allowlist for local use.
# Example: GOOGLE_ADS_CUSTOMER_IDS="1234567890,9876543210"
GOOGLE_ADS_CUSTOMER_IDS=""
META_AD_ACCOUNT_IDS=""
